{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "mul-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-agent collaboration system",
  "keywords": [
    "agent",
    "ai",
    "llm",
    "multi-agent"
  ],
  "homepage": "https://github.com/your-org/mul-agent#readme",
  "bugs": {
    "url": "https://github.com/your-org/mul-agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/mul-agent.git"
  },
  "license": "MIT",
  "author": "your-org",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mulagent": "./src/cli/repl.ts"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist/",
    "docs/",
    "mul_agent/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc -b && cd ui && vite build",
    "dev": "cd ui && pnpm dev",
    "api": "npx tsx src/api/server.ts",
    "api:dev": "tsx src/api/server.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "format": "oxfmt write ui/**/*.ts ui/**/*.tsx",
    "format:check": "oxfmt check ui/**/*.ts ui/**/*.tsx",
    "format:write": "oxfmt write ui/**/*.ts ui/**/*.tsx",
    "check": "pnpm lint && pnpm format:check",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "mammoth": "^1.12.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "edge-tts": "^1.0.1",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
