# ===========================================
# LLM Provider Configuration
# ===========================================
# The system will automatically choose the provider based on which keys are configured.
# Priority: Baidu Qianfan > Anthropic/MiniMax
# ===========================================

# -------------------------------------------
# Baidu Qianfan ( ernie-bot with image understanding )
# -------------------------------------------
# Get API keys from: https://console.bce.baidu.com/qianfan/
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# Available models with image understanding:
# - ernie-bot-4.0: ERNIE Bot 4.0
# - ernie-bot-3.5: ERNIE Bot 3.5
# - ernie-bot-8k: ERNIE Bot with 8K context
# - eb-instant: Fast inference model
BAIDU_MODEL=ernie-bot-4.0

# -------------------------------------------
# Anthropic / MiniMax ( claude with image understanding )
# -------------------------------------------
# Get API key from: https://console.anthropic.com/
ANTHROPIC_AUTH_TOKEN=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For MiniMax (Anthropic-compatible API):
# ANTHROPIC_BASE_URL=https://api.minimax.chat/v1

# -------------------------------------------
# Usage Examples
# -------------------------------------------
#
# 1. Use Baidu Qianfan (with image support):
#    Set BAIDU_API_KEY and BAIDU_SECRET_KEY
#
# 2. Use Anthropic Claude (with image support):
#    Set ANTHROPIC_AUTH_TOKEN
#
# 3. Use MiniMax (Anthropic-compatible):
#    Set ANTHROPIC_AUTH_TOKEN and ANTHROPIC_BASE_URL=https://api.minimax.chat/v1
#
# -------------------------------------------
